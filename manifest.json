{
  "manifest_version": 3,
  "name": "Chaicode Player Boost",
  "version": "1.8.20",
  "description": "Enhances Chaicode course videos with custom controls and seeking. Active only on courses.chaicode.com.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_title": "Chaicode Player Boost",
    "default_icon": {
      "128": "icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://courses.chaicode.com/*"
      ],
      "js": [
        "unlock-seek.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://courses.chaicode.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
